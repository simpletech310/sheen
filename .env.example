NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Personal access token from https://supabase.com/dashboard/account/tokens
# Only needed for the one-shot email-template push script.
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

NEXT_PUBLIC_MAPBOX_TOKEN=
RESEND_API_KEY=
TWILIO_AUTH_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (PWA notifications). Generate with `npx web-push generate-vapid-keys`
# and stash the matching pair. Without these, push subscription is a no-op
# and the welcome flow's notification step quietly skips.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@example.com
